{
  "name": "word-bank",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "APP_VARIANT=development expo run:android",
    "ios": "APP_VARIANT=development expo run:ios",
    "web": "expo start --web",
    "dev": "APP_VARIANT=development npx expo start --dev-client --clear --android --ios",
    "dev-client:physical": "APP_VARIANT=development expo start --dev-client --clear",
    "dev-client:android": "APP_VARIANT=development expo start --dev-client --android --clear",
    "dev-client:ios": "APP_VARIANT=development expo start --dev-client --ios --clear",
    "lint": "expo lint",
    "build:all": "npx eas build --platform all --profile development",
    "build:android": "npx eas build --platform android --profile development",
    "build:ios": "npx eas build --platform ios --profile development",
    "build:apk": "npx eas build --platform android --profile preview",
    "build:dev": "npx eas build --platform android --profile development",
    "build:dev:ios": "npx eas build --platform ios --profile development",
    "build:apk:local:dev": "APP_VARIANT=development expo prebuild --platform android --clean && (cd android && ./gradlew assembleDebug) && mkdir -p builds/dev && cp android/app/build/outputs/apk/debug/app-debug.apk builds/dev/ && echo '\\nAPK: builds/dev/app-debug.apk'",
    "build:apk:local:preview": "APP_VARIANT=preview expo prebuild --platform android --clean && (cd android && ./gradlew assembleRelease) && mkdir -p builds/preview && cp android/app/build/outputs/apk/release/app-release.apk builds/preview/ && APP_VARIANT=development expo prebuild --platform android --clean --no-install && echo '\\nAPK: builds/preview/app-release.apk'",
    "build:apk:local:all": "npm run build:apk:local:dev && npm run build:apk:local:preview",
    "update:preview": "eas update --branch preview --auto"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.24",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.7",
    "expo-glass-effect": "~55.0.11",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}